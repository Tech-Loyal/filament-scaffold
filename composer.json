{
    "name": "solution-forest/filament-scaffold",
    "description": "Filament Scaffold - Generates resources, models, migrations and more for Filament Admin v4/v5",
    "keywords": [
        "solution-forest",
        "laravel",
        "filament",
        "filament-scaffold",
        "scaffold",
        "generator"
    ],
    "homepage": "https://github.com/solutionforest/filament-scaffold",
    "support": {
        "issues": "https://github.com/solutionforest/filament-scaffold/issues",
        "source": "https://github.com/solutionforest/filament-scaffold"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "celia514",
            "email": "info+package@solutionforest.net",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "spatie/laravel-package-tools": "^1.16.0",
        "illuminate/support": "^11.28 || ^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "nunomaduro/larastan": "^3.0",
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Solutionforest\\FilamentScaffold\\": "src/",
            "Solutionforest\\FilamentScaffold\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Solutionforest\\FilamentScaffold\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Solutionforest\\FilamentScaffold\\FilamentScaffoldServiceProvider"
            ],
            "aliases": {
                "FilamentScaffold": "Solutionforest\\FilamentScaffold\\Facades\\FilamentScaffold"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
